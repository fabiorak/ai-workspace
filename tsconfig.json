{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@ai-workspace/core": ["./packages/core/src/index.ts"],
      "@ai-workspace/codex-adapter": ["./integrations/codex/src/index.ts"],
      "@ai-workspace/git-adapter": ["./integrations/git/src/index.ts"],
      "@ai-workspace/historical-search": [
        "./packages/historical-search/src/index.ts"
      ],
      "@ai-workspace/local-session-ingestion": [
        "./integrations/local-session-ingestion/src/index.ts"
      ],
      "@ai-workspace/local-project-registry": [
        "./integrations/local-project-registry/src/index.ts"
      ],
      "@ai-workspace/project-registry": [
        "./packages/project-registry/src/index.ts"
      ],
      "@ai-workspace/session-ingestion": [
        "./packages/session-ingestion/src/index.ts"
      ]
    },
    "types": ["node"]
  },
  "include": [
    "apps/**/*.ts",
    "integrations/**/*.ts",
    "packages/**/*.ts",
    "services/**/*.ts"
  ],
  "exclude": ["**/dist/**", "node_modules"]
}
