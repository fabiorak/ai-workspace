{
  "name": "ai-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first control plane for cross-agent AI work",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "integrations/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json --pretty false",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run test",
    "cli": "node apps/cli/dist/main.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gui": "node apps/web/dist/main.js",
    "lint": "eslint .",
    "measure:entity-candidates": "node scripts/entity-candidate-measurement.ts",
    "measure:general-links": "node scripts/general-link-scale-measurement.ts",
    "measure:output-restoration": "node scripts/output-restoration-measurement.ts",
    "measure:privacy-audit": "node scripts/privacy-audit-measurement.ts",
    "measure:delivery-authorization": "node scripts/model-delivery-authorization-measurement.ts",
    "measure:openai-responses": "node scripts/openai-responses-qualification-measurement.ts",
    "measure:openai-at-most-once": "node scripts/openai-at-most-once-attempt-measurement.ts",
    "measure:codex-headless": "node scripts/codex-headless-qualification-measurement.ts",
    "measure:anthropic-messages": "node scripts/anthropic-messages-qualification-measurement.ts",
    "measure:claude-headless": "node scripts/claude-headless-qualification-measurement.ts",
    "test": "node --test apps/*/test/*.test.ts integrations/*/test/*.test.ts packages/*/test/*.test.ts",
    "test:watch": "node --test --watch apps/*/test/*.test.ts integrations/*/test/*.test.ts packages/*/test/*.test.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
