{
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@ai-workspace/active-memory": ["./packages/active-memory/src/index.ts"],
      "@ai-workspace/core": ["./packages/core/src/index.ts"],
      "@ai-workspace/codex-adapter": ["./integrations/codex/src/index.ts"],
      "@ai-workspace/claude-code-adapter": [
        "./integrations/claude-code/src/index.ts"
      ],
      "@ai-workspace/context-builder": [
        "./packages/context-builder/src/index.ts"
      ],
      "@ai-workspace/git-adapter": ["./integrations/git/src/index.ts"],
      "@ai-workspace/general-conversation": [
        "./packages/general-conversation/src/index.ts"
      ],
      "@ai-workspace/historical-search": [
        "./packages/historical-search/src/index.ts"
      ],
      "@ai-workspace/handoff": ["./packages/handoff/src/index.ts"],
      "@ai-workspace/instruction-manager": [
        "./packages/instruction-manager/src/index.ts"
      ],
      "@ai-workspace/local-session-ingestion": [
        "./integrations/local-session-ingestion/src/index.ts"
      ],
      "@ai-workspace/local-project-registry": [
        "./integrations/local-project-registry/src/index.ts"
      ],
      "@ai-workspace/local-active-memory": [
        "./integrations/local-active-memory/src/index.ts"
      ],
      "@ai-workspace/local-general-conversation": [
        "./integrations/local-general-conversation/src/index.ts"
      ],
      "@ai-workspace/local-handoffs": [
        "./integrations/local-handoffs/src/index.ts"
      ],
      "@ai-workspace/local-instructions": [
        "./integrations/local-instructions/src/index.ts"
      ],
      "@ai-workspace/local-work-items": [
        "./integrations/local-work-items/src/index.ts"
      ],
      "@ai-workspace/project-registry": [
        "./packages/project-registry/src/index.ts"
      ],
      "@ai-workspace/privacy-gateway": [
        "./packages/privacy-gateway/src/index.ts"
      ],
      "@ai-workspace/local-privacy-policy": [
        "./integrations/local-privacy-policy/src/index.ts"
      ],
      "@ai-workspace/session-ingestion": [
        "./packages/session-ingestion/src/index.ts"
      ]
    },
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"],
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true
  }
}
